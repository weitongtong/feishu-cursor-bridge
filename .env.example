# === 飞书应用配置 ===
# 在飞书开放平台创建应用后获取
FEISHU_APP_ID=cli_xxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxx

# === Cursor CLI 配置 ===
# 通过 agent login 登录后也可自动获取，或在此手动设置
CURSOR_API_KEY=

# 默认工作目录（Cursor CLI 将在此目录下执行）
DEFAULT_WORK_DIR=/path/to/your/project

# 默认模型名称，不填则使用 Cursor 默认模型
# DEFAULT_MODEL=gpt-5.2

# Cursor CLI 执行超时时间（毫秒），默认 300000（5分钟）
# CURSOR_TIMEOUT_MS=300000

# Cursor CLI 可执行文件名，默认为 agent
# CURSOR_BIN=agent

# 默认模式（agent / ask / plan / cloud），队列排空时使用，默认 plan
# DEFAULT_MODE=plan

# === TOS 对象存储配置（DeskClaw 打包上传工具使用） ===
TOS_ACCESS_KEY_ID=your_access_key_id
TOS_SECRET_ACCESS_KEY=your_secret_access_key
# TOS_ENDPOINT=https://tos-s3-cn-beijing.volces.com
# TOS_REGION=cn-beijing
# TOS_BUCKET=nodeskai-public
# TOS_KEY_PREFIX=deskclaw/test-pg/
